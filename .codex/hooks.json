{
  "PreToolUse": [
    {
      "matcher": "^Bash$",
      "hooks": [
        {
          "type": "command",
          "command": "bash scripts/agent/guard-pr.sh",
          "timeout": 30,
          "statusMessage": "Checking repo workflow guardrails"
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": "Edit|MultiEdit|Write",
      "hooks": [
        {
          "type": "command",
          "command": "bash scripts/agent/check-instructions.sh warn",
          "timeout": 30,
          "statusMessage": "Validating shared agent instructions"
        }
      ]
    }
  ]
}
