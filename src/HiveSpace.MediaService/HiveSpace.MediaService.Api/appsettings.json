{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "Database": {
    "MediaServiceDb": "Server=localhost,1433;Database=MediaDb;User Id=sa;Encrypt=False;TrustServerCertificate=True"
  },
  "Authentication": {
    "Authority": "http://localhost:5001",
    "Audience": "media",
    "RequireHttpsMetadata": false
  },
  "AzureStorage": {
    "ConnectionString": "DefaultEndpointsProtocol=http;AccountName=devstoreaccount1",
    "TempContainer": "temp-media-upload",
    "PublicContainer": "public-assets",
    "QueueName": "image-processing-queue",
    "CdnHost": ""
  },
  "Messaging": {
    "EnableRabbitMq": true,
    "EnableKafka": false,
    "RabbitMq": {
      "Host": "localhost",
      "Port": 5672,
      "Username": "guest",
      "Password": "guest"
    },
    "Kafka": {
      "BootstrapServers": "localhost:9092",
      "ClientId": "catalog-service",
      "ConsumerGroup": "catalog-service",
      "SecurityProtocol": "PLAINTEXT"
    }
  },
  "MediaService": {
    "PresignUrlExpiryMinutes": 10
  },
  "MediaCleanup": {
    "ExpirationHours": 24,
    "BatchSize": 100
  }
}