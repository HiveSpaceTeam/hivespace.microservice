{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.Authentication": "Debug",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
      "MassTransit": "Warning",
      "MassTransit.EntityFrameworkCoreIntegration": "None"
    }
  },
  "ConnectionStrings": {
    "MediaDb": "Server=localhost,1433;Database=MediaDb;User Id=sa;Password=;Encrypt=False;TrustServerCertificate=True",
    "RabbitMq": "amqp://guest@localhost:5672/",
    "Kafka": "localhost:9092",
    "AzureStorage": "DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey="
  },
  "Authentication": {
    "Authority": "http://localhost:5001",
    "Audience": "media",
    "RequireHttpsMetadata": false
  },
  "AzureStorage": {
    "TempContainer": "temp-media-upload",
    "PublicContainer": "public-assets",
    "QueueName": "image-processing-queue",
    "CdnHost": ""
  },
  "Messaging": {
    "EnableRabbitMq": true,
    "EnableKafka": false,
    "Kafka": {
      "ClientId": "catalog-service",
      "ConsumerGroup": "catalog-service",
      "SecurityProtocol": "PLAINTEXT"
    }
  },
  "MediaService": {
    "PresignUrlExpiryMinutes": 10
  },
  "MediaCleanup": {
    "ExpirationHours": 24,
    "BatchSize": 100
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.AspNetCore.Authentication": "Debug",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "MassTransit": "Warning",
        "MassTransit.EntityFrameworkCoreIntegration": "Fatal",
        "System": "Warning"
      }
    }
  }
}