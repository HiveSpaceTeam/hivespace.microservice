{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.Authentication": "Debug",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
      "MassTransit": "Warning",
      "MassTransit.EntityFrameworkCoreIntegration": "None"
    }
  },
  "ConnectionStrings": {
    "CatalogDb": "Server=localhost,1433;Database=CatalogDb;User Id=sa;;Encrypt=False;TrustServerCertificate=True",
    "RabbitMq": "amqp://guest:@localhost:5672/",
    "Kafka": "localhost:9092"
  },
  "Authentication": {
    "Authority": "http://localhost:5001",
    "Audience": "catalog",
    "RequireHttpsMetadata": false
  },
  "Messaging": {
    "EnableRabbitMq": true,
    "EnableKafka": false,
    "Kafka": {
      "ClientId": "catalog-service",
      "ConsumerGroup": "catalog-service",
      "SecurityProtocol": "PLAINTEXT"
    }
  },
  "AllowedHosts": "*",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.AspNetCore.Authentication": "Debug",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "MassTransit": "Warning",
        "MassTransit.EntityFrameworkCoreIntegration": "Fatal",
        "System": "Warning"
      }
    }
  }
}
