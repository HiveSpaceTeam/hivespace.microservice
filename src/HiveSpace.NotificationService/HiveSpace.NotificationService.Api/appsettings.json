{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.Authentication": "Debug",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
      "MassTransit": "Warning",
      "MassTransit.EntityFrameworkCoreIntegration": "None"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "NotificationDb": "Server=tcp:127.0.0.1,1433;Database=NotificationDb;User Id=sa;Encrypt=False;TrustServerCertificate=True",
    "Redis": "localhost:6379,abortConnect=false",
    "RabbitMq": "amqp://guest:@localhost:5672/"
  },
  "Authentication": {
    "Authority": "http://localhost:5001",
    "Audience": "notification",
    "RequireHttpsMetadata": false
  },
  "Messaging": {
    "EnableRabbitMq": true,
    "EnableKafka": false,
    "RabbitMq": {
      "DuplicateDetectionWindowMinutes": 5,
      "OutboxQueryDelaySeconds": 1,
      "OutboxQueryMessageLimit": 100,
      "OutboxQueryTimeoutSeconds": 60,
      "OutboxMessageDeliveryLimit": 50
    }
  },
  "Resend": {
    "ApiToken": ""
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.AspNetCore.Authentication": "Debug",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "MassTransit": "Warning",
        "MassTransit.EntityFrameworkCoreIntegration": "Fatal",
        "System": "Warning"
      }
    }
  }
}