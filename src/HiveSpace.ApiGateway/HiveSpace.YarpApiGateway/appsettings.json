{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AllowedOrigins": [
    "http://localhost:5173",
    "http://localhost:5174",
    "http://localhost:5175"
  ],
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "user-cluster",
        "Match": {
          "Path": "/identity/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/identity"
          }
        ]
      },
      "user-route": {
        "ClusterId": "user-cluster",
        "Match": {
          "Path": "/api/v{version}/users/{**catch-all}"
        }
      },
      "account-route": {
        "ClusterId": "user-cluster",
        "Match": {
          "Path": "/api/v{version}/accounts/{**catch-all}"
        }
      },
      "admin-route": {
        "ClusterId": "user-cluster",
        "Match": {
          "Path": "/api/v{version}/admins/{**catch-all}"
        }
      },
      "store-route": {
        "ClusterId": "user-cluster",
        "Match": {
          "Path": "/api/v{version}/stores/{**catch-all}"
        }
      },
      "categories-route": {
        "ClusterId": "catalog-cluster",
        "Match": {
          "Path": "/api/v{version}/categories/{**catch-all}"
        }
      },
      "products-route": {
        "ClusterId": "catalog-cluster",
        "Match": {
          "Path": "/api/v{version}/products/{**catch-all}"
        }
      },
      "medias-route": {
        "ClusterId": "media-cluster",
        "Match": {
          "Path": "/api/v{version}/media/{**catch-all}"
        }
      },
      "coupons-route": {
        "ClusterId": "order-cluster",
        "Match": {
          "Path": "/api/v{version}/coupons/{**catch-all}"
        }
      },
      "carts-route": {
        "ClusterId": "order-cluster",
        "Match": {
          "Path": "/api/v{version}/carts/{**catch-all}"
        }
      },
      "orders-route": {
        "ClusterId": "order-cluster",
        "Match": {
          "Path": "/api/v{version}/orders/{**catch-all}"
        }
      },
      "payments-route": {
        "ClusterId": "payment-cluster",
        "Match": {
          "Path": "/api/v{version}/payments/{**catch-all}"
        }
      },
      "wallets-route": {
        "ClusterId": "payment-cluster",
        "Match": {
          "Path": "/api/v{version}/wallets/{**catch-all}"
        }
      },
      "notifications-route": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/api/v{version}/notifications/{**catch-all}"
        }
      },
      "notification-preferences-route": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/api/v{version}/preferences/{**catch-all}"
        }
      },
      "notification-hub-route": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/hubs/notifications/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "user-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5001"
          }
        }
      },
      "catalog-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5002"
          }
        }
      },
      "media-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5003"
          }
        }
      },
      "order-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5004"
          }
        }
      },
      "payment-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5005"
          }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5006"
          }
        }
      }
    }
  }
}