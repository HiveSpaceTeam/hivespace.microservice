{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.Authentication": "Debug",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
      "MassTransit": "Warning",
      "MassTransit.EntityFrameworkCoreIntegration": "None"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "OrderDb": "Server=localhost,1433;Database=OrderDb;User Id=sa;Password=;Encrypt=False;TrustServerCertificate=True",
    "RabbitMq": "amqp://guest:@localhost:5672/",
    "Kafka": "localhost:9092"
  },
  "Authentication": {
    "Authority": "http://localhost:5001",
    "Audience": "order",
    "RequireHttpsMetadata": false
  },
  "Messaging": {
    "EnableRabbitMq": true,
    "EnableKafka": false,
    "RabbitMq": {
      "DuplicateDetectionWindowMinutes": 5,
      "OutboxQueryDelaySeconds": 1,
      "OutboxQueryMessageLimit": 100,
      "OutboxQueryTimeoutSeconds": 60,
      "OutboxMessageDeliveryLimit": 50
    },
    "Kafka": {
      "ClientId": "order-service",
      "ConsumerGroup": "order-service",
      "SecurityProtocol": "PLAINTEXT"
    }
  },
  "Snowflake": {
    "DatacenterId": 0,
    "MachineId": 0
  },
  "Payment": {
    "ReturnUrl": "http://localhost:5005/api/v1/payments/vnpay/return",
    "IpnUrl": "http://localhost:5005/api/v1/payments/webhook/vnpay"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.AspNetCore.Authentication": "Debug",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "MassTransit": "Warning",
        "MassTransit.EntityFrameworkCoreIntegration": "Fatal",
        "System": "Warning"
      }
    }
  }
}