{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "ConnectionStrings": {
        "DefaultConnection": "Server=localhost,1433;Database=IdentityDb;User Id=sa;Encrypt=False;TrustServerCertificate=True"
    },
    "Authentication": {
        "Authority": "http://localhost:5001",
        "Audience": "identity",
        "RequireHttpsMetadata": false,
        "Google": {
            "ClientId": "",
            "ClientSecret": "",
            "CallbackPath": "/api/v1/accounts/external/google/callback",
            "PublicCallbackOrigin": "http://localhost:5000",
            "PendingLinkLifetimeMinutes": 10,
            "ProviderDisplayName": "Google",
            "AllowedFrontendOrigins": {
                "seller": "http://localhost:5174",
                "buyer": "http://localhost:5175"
            }
        }
    },
    "DefaultRedirectUrl": "http://localhost:5175",
    "BrowserSession": {
        "AccessTokenCookieName": "__Host-HiveSpace.AccessToken",
        "RefreshTokenCookieName": "__Host-HiveSpace.RefreshToken",
        "CsrfCookieName": "HiveSpace.Csrf",
        "CsrfHeaderName": "X-HiveSpace-CSRF",
        "SigningKey": "",
        "AccessTokenMinutes": 15,
        "RefreshTokenDays": 30,
        "AccessTokenScopes": [
            "identity.fullaccess",
            "user.fullaccess",
            "catalog.fullaccess",
            "order.fullaccess",
            "media.fullaccess",
            "payment.fullaccess",
            "notification.fullaccess"
        ],
        "AccessTokenAudiences": [
            "identity",
            "user",
            "catalog",
            "order",
            "media",
            "payment",
            "notification"
        ]
    },
    "FrontendRedirects": {
        "admin": {
            "Origin": "http://localhost:5173",
            "loginPath": "/signin",
            "registerPath": "/signin",
            "logoutPath": "/signin"
        },
        "seller": {
            "Origin": "http://localhost:5174",
            "loginPath": "/signin",
            "registerPath": "/signup",
            "logoutPath": "/signin"
        },
        "buyer": {
            "Origin": "http://localhost:5175",
            "loginPath": "/signin",
            "registerPath": "/signup",
            "logoutPath": "/signin"
        }
    },
    "Issuer": "http://localhost:5001",
    "Clients": {
